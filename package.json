{
    "name": "wdio-practice",
    "type": "module",
    "imports": {
        "#pages/*": "./test/page-objects/pages/*",
        "#forms/*": "./test/page-objects/forms/*",
        "#test/*": "./test/*"
    },
    "devDependencies": {
        "@wdio/cli": "^9.23.0",
        "@wdio/local-runner": "^9.23.0",
        "@wdio/mocha-framework": "^9.23.0",
        "@wdio/spec-reporter": "^9.20.0",
        "dotenv": "^17.2.3"
    },
    "scripts": {
        "wdio": "wdio run ./wdio.conf.js",
        "wdio:pom": "wdio run ./wdio.conf.js --spec ./test/specs/pom-tests/**/*.e2e.js",
        "wdio:signin": "wdio run ./wdio.conf.js --spec ./test/specs/pom-tests/signinForm.e2e.js",
        "wdio:garage": "wdio run ./wdio.conf.js --spec ./test/specs/pom-tests/garagePage.e2e.js"
    }
}
